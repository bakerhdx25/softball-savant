<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.softball-savant-update</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/openclaw/ausl/softball-savant/bin/update-official-public.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/openclaw/ausl</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/openclaw/ausl/softball-savant/logs/daily-update.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/openclaw/ausl/softball-savant/logs/daily-update.err.log</string>
</dict>
</plist>
